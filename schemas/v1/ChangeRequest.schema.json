{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChangeRequest",
  "type": "object",
  "required": [
    "change_request_id", "idempotency_key", "source_system", "source_reference_id",
    "requester", "business_owner", "technical_owner",
    "environment", "firewall_domain",
    "action", "operation_mode", "priority",
    "flows", "justification", "required_approvals", "approver_roles"
  ],
  "properties": {
    "change_request_id": {"type": "string"},
    "idempotency_key": {"type": "string"},
    "source_system": {"type": "string"},
    "source_reference_id": {"type": "string"},
    "requester": {"type": "object", "required": ["id"], "properties": {"id": {"type": "string"}}, "additionalProperties": true},
    "business_owner": {"type": "object", "required": ["id"], "properties": {"id": {"type": "string"}}, "additionalProperties": true},
    "technical_owner": {"type": "object", "required": ["id"], "properties": {"id": {"type": "string"}}, "additionalProperties": true},
    "environment": {"type": "string"},
    "firewall_domain": {"type": "string"},
    "device_group": {"type": "string"},
    "policy_scope": {"type": "string"},
    "action": {"type": "string", "enum": ["allow", "deny", "modify", "remove"]},
    "operation_mode": {"type": "string", "enum": ["plan_only", "apply_enabled"]},
    "priority": {"type": "string", "enum": ["low", "normal", "high", "urgent"]},
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["flow_id", "src", "dst", "service", "direction"],
        "properties": {
          "flow_id": {"type": "string"},
          "src": {"type": "string"},
          "dst": {"type": "string"},
          "service": {"type": "string"},
          "direction": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "justification": {"type": "string", "minLength": 1},
    "required_approvals": {"type": "integer", "minimum": 1},
    "approver_roles": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "oneOf": [
    {"required": ["device_group"]},
    {"required": ["policy_scope"]}
  ],
  "additionalProperties": true
}
